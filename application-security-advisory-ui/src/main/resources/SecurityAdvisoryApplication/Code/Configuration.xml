&lt;div class="box"&gt;
  &lt;form action="$escapetool.xml($formUrl)" method="post" class="xform"&gt;
    &lt;input type="hidden" name="form_token" value="$!{services.csrf.getToken()}"/&gt;
    &lt;input type="hidden" name="xredirect" value="$escapetool.xml($xwiki.relativeRequestURL)"/&gt;
    &lt;input type="hidden" name="githubTokenAction" value="removeToken"/&gt;
    &lt;input type="hidden" name="githubTokenToRemove" value="$escapetool.xml($token.number)"/&gt;
    &lt;p&gt;
      $services.localization.render('securityadvisoryapplication.admin.githubTokens.column.orga'): 
      $escapetool.xml($token.get('orga'))
      &lt;button type="submit" class="btn btn-danger btn-xs" title="$escapetool.xml($services.localization.render('securityadvisoryapplication.admin.githubTokens.remove'))"&gt;$services.icon.renderHTML('cross')&lt;/button&gt;
    &lt;/p&gt;
  &lt;/form&gt;
&lt;/div&gt;
  #end
#else
&lt;p&gt;$escapetool.xml($services.localization.render('securityadvisoryapplication.admin.githubTokens.empty'))&lt;/p&gt;
#end
