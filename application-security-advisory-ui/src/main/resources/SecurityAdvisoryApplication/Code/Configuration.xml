#if($xwiki.hasAdminRights() &amp;&amp; "$!request.get('githubTokenAction')" != '')
#set($githubTokenClass = 'SecurityAdvisoryApplication.Code.GithubTokenClass')
#if ($services.csrf.isTokenValid($request.get('form_token')))
  #set($redirectURL = $request.get('xredirect'))
  #if($request.get('githubTokenAction') == 'addToken')
    #set($newOrga = $request.get('newOrga'))
    #set($newTokenValue = $request.get('newToken'))
    #if("$!newOrga" != '' &amp;&amp; "$!newTokenValue" != '')
      #set($newObj = $doc.newObject($githubTokenClass))
      #set($discard = $newObj.set('orga', $newOrga))
      #set($discard = $newObj.set('token', $newTokenValue))
      #set($discard = $doc.save('Add GitHub token', true))
      $response.sendRedirect($redirectURL)
    #else
      #set ($discard = $response.sendError(400, 'Missing arguments.'))
    #end
  #elseif ($request.get('githubTokenAction') == 'removeToken')
    #set($removeTokenNum = $request.get('githubTokenToRemove'))
    #if("$!removeTokenNum" != '')
      #set($objToRemove = $null)
      #foreach($token in $doc.getObjects($githubTokenClass))
        #if("$token.number" == $removeTokenNum.trim())
          #set($objToRemove = $token)
        #end
      #end
      #if($objToRemove)
        #set($discard = $doc.removeObject($objToRemove))
        #set($discard = $doc.save('Remove GitHub token', true))
        $response.sendRedirect($redirectURL)
      #else
        #set ($discard = $response.sendError(404, 'Token not found.'))
      #end
    #else
      #set ($discard = $response.sendError(400, 'Missing arguments.'))
    #end
  #else
    #set ($discard = $response.sendError(400, 'Action not recognized.'))
  #end
#else
  #set ($discard = $response.sendError(401, 'CSRF token verification failed.'))
#end
#else
  Hold configuration objects.
#end
{{/velocity}}</content>
