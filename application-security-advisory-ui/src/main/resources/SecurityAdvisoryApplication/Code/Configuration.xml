      &lt;dt&gt;&lt;label for="newToken"&gt;$escapetool.xml($services.localization.render('securityadvisoryapplication.admin.githubTokens.column.token'))&lt;/label&gt;&lt;/dt&gt;
      &lt;dd&gt;&lt;input type="password" id="newToken" name="newToken" class="form-control" required="required"/&gt;&lt;/dd&gt;
